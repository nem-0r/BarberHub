# Frontend production env — sample.
# Set these in Vercel dashboard (Project → Settings → Environment Variables).
# NEXT_PUBLIC_* are inlined into the bundle at build time, so you must
# redeploy the frontend after changing them.

# The Render backend URL — replace with the one Render assigns you.
NEXT_PUBLIC_API_URL=https://barberhub-api.onrender.com

# Optional: Google OAuth Client ID. Leave empty to hide the "Sign in with Google"
# button. Same value as the backend's GOOGLE_CLIENT_ID env var.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
